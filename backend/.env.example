# AWS
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# DynamoDB 테이블명
DYNAMO_BLAME_TABLE=codewhy_blame_cache
DYNAMO_TIMELINE_TABLE=codewhy_timeline_cache

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key

# 기획서/문서 폴더 경로 (쉼표 구분)
DOCUMENT_PATHS=/path/to/docs,/path/to/specs
